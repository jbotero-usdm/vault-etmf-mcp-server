{
  "version": 2,
  "builds": [
    {
      "src": "vault_etmf_mcp.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "vault_etmf_mcp.py"
    }
  ],
  "env": {
    "VAULT_ETMF_DNS": "@vault_etmf_dns",
    "VAULT_ETMF_USERNAME": "@vault_etmf_username",
    "VAULT_ETMF_PASSWORD": "@vault_etmf_password"
  }
}
